[Unit]
Description=llama.cpp local LLM server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory={{ORACLE_DIR}}
EnvironmentFile=-{{ORACLE_DIR}}/.env
Environment=LLAMA_MODEL={{ORACLE_DIR}}/models/gemma-4-E2B-it-UD-Q2_K_XL.gguf
ExecStart={{ORACLE_DIR}}/scripts/run_llama_server.sh
Restart=on-failure
RestartSec=5
User={{ORACLE_USER}}

[Install]
WantedBy=multi-user.target
