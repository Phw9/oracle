[Unit]
Description=Oracle on-device Flask app
After=network-online.target llama-server.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/hyukju/work/oracle
EnvironmentFile=-/home/hyukju/work/oracle/.env
ExecStart=/home/hyukju/work/oracle/run.sh
Restart=on-failure
RestartSec=5
User=hyukju

[Install]
WantedBy=multi-user.target
