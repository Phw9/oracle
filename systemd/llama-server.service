[Unit]
Description=llama.cpp local LLM server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/tmdwls/projects/oracle
EnvironmentFile=-/home/tmdwls/projects/oracle/.env
Environment=LLAMA_MODEL=/home/tmdwls/projects/oracle/models/gemma-4-E2B-it-UD-Q2_K_XL.gguf
ExecStart=/home/tmdwls/projects/oracle/scripts/run_llama_server.sh
Restart=on-failure
RestartSec=5
User=tmdwls

[Install]
WantedBy=multi-user.target
